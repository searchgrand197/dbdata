DJANGO_ENV=development
DEBUG=1
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ALLOW_ALL_ORIGINS=1
CORS_ALLOWED_ORIGINS=

# Production: set your domain for email links, CSRF, etc.
SITE_BASE_URL=http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=
SECURE_SSL_REDIRECT=False

# Pagination
PAGE_SIZE=20

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# Email / SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtpout.secureserver.net
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=support@intvice.com
EMAIL_HOST_PASSWORD=Nvn$aroy001
DEFAULT_FROM_EMAIL=support@intvice.com
SERVER_EMAIL=support@intvice.com

# PostgreSQL (set POSTGRES_DB to enable Postgres)
POSTGRES_DB=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Logging
LOG_LEVEL=INFO

